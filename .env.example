# TokenPay ID — Environment Variables
# Copy this file to .env and fill in all values before running docker-compose

# Database
DB_HOST=5.23.55.152
DB_PORT=5432
DB_NAME=default_db
DB_USER=gen_user
DB_PASSWORD=CHANGE_ME

# JWT Secrets (use long random strings, e.g. openssl rand -hex 64)
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Admin account (created on first run)
ADMIN_EMAIL=info@tokenpay.space
ADMIN_PASSWORD=CHANGE_ME

# SMTP (optional — emails logged to console if not set)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=info@tokenpay.space
SMTP_PASS=
SMTP_FROM=noreply@tokenpay.space
