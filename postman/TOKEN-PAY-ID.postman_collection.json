{
  "info": {
    "name": "TOKEN PAY ID API",
    "description": "Official Postman collection for TOKEN PAY ID — unified authentication platform by TOKEN PAY LLC.\n\nBase URL: https://tokenpay.space\nDocs: https://tokenpay.space/docs\nContact: info@tokenpay.space",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://tokenpay.space", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "public_key", "value": "", "type": "string" },
    { "key": "secret_key", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/health",
            "description": "Check API health status"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Send Verification Code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/send-code",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"type\": \"register\",\n  \"name\": \"Ivan Ivanov\",\n  \"lang\": \"ru\"\n}"
            },
            "description": "Send email verification code for register or login"
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.accessToken) {",
                  "  pm.collectionVariables.set('access_token', d.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', d.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Ivan Ivanov\",\n  \"email_code\": \"123456\"\n}"
            },
            "description": "Register a new user. Saves accessToken and refreshToken to collection variables."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.accessToken) {",
                  "  pm.collectionVariables.set('access_token', d.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', d.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"email_code\": \"123456\"\n}"
            },
            "description": "Login and get JWT tokens."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.accessToken) pm.collectionVariables.set('access_token', d.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"code\": \"123456\",\n  \"new_password\": \"NewSecurePass123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Get current authenticated user profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ivan Ivanov\",\n  \"locale\": \"ru\",\n  \"theme\": \"dark\"\n}"
            }
          }
        },
        {
          "name": "Activity Log",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/activity?limit=20",
              "query": [{ "key": "limit", "value": "20" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Active Sessions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/users/sessions/SESSION_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Connected Apps",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/connected-apps",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "API Keys (Enterprise)",
      "item": [
        {
          "name": "List Keys",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/keys",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Enterprise/admin only. Lists all API keys."
          }
        },
        {
          "name": "Create Permanent Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.public_key) pm.collectionVariables.set('public_key', d.public_key);",
                  "if (d.secret_key) pm.collectionVariables.set('secret_key', d.secret_key);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/keys",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Production Key\"\n}"
            },
            "description": "Create a permanent API key pair. Secret shown ONCE."
          }
        },
        {
          "name": "Create Temporary Key (30 days)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/keys",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Temp Key — 30 days\",\n  \"expires_in_days\": 30\n}"
            },
            "description": "Create a temporary key that expires in 30 days."
          }
        },
        {
          "name": "Revoke Key",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/keys/KEY_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "OAuth 2.0",
      "item": [
        {
          "name": "Token Exchange (auth_code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.access_token) pm.collectionVariables.set('access_token', d.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/oauth/token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"authorization_code\",\n  \"code\": \"tpid_code_...\",\n  \"client_id\": \"{{public_key}}\",\n  \"client_secret\": \"{{secret_key}}\",\n  \"redirect_uri\": \"https://yourapp.com/callback\",\n  \"code_verifier\": \"YOUR_PKCE_VERIFIER\"\n}"
            }
          }
        },
        {
          "name": "Token Refresh (OAuth)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/oauth/token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"refresh_token\": \"{{refresh_token}}\",\n  \"client_id\": \"{{public_key}}\",\n  \"client_secret\": \"{{secret_key}}\"\n}"
            }
          }
        },
        {
          "name": "UserInfo (OIDC)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/oauth/userinfo",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/oauth/revoke",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{access_token}}\",\n  \"client_id\": \"{{public_key}}\",\n  \"client_secret\": \"{{secret_key}}\"\n}"
            }
          }
        },
        {
          "name": "OpenID Discovery",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/.well-known/openid-configuration"
          }
        },
        {
          "name": "JWKS",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/.well-known/jwks.json"
          }
        }
      ]
    },
    {
      "name": "Enterprise",
      "item": [
        {
          "name": "Apply for Enterprise",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/enterprise/apply",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"Your Company LLC\",\n  \"website\": \"https://yourcompany.com\",\n  \"description\": \"We build payment solutions\"\n}"
            }
          }
        },
        {
          "name": "Application Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/enterprise/application",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Connected Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/enterprise/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/enterprise/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/enterprise/settings",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/enterprise/settings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"callback_url\": \"https://yourapp.com/callback\"\n}"
            }
          }
        }
      ]
    }
  ]
}
